{
  "expo": {
    "name": "MAKERSFLOW",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logos/icon.webp",
    "scheme": "makersflow",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash/splash.webp",
      "resizeMode": "contain",
      "backgroundColor": "#0B6FAD"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.makersflow.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logos/icon.webp",
        "backgroundColor": "#0B6FAD"
      },
      "package": "com.makersflow.mobile",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "makersflow",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "makersflow"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.USE_FINGERPRINT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.INTERNET",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.WAKE_LOCK"
      ],
      "minSdkVersion": 24
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-video",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#0B6FAD"
        }
      ],
      "expo-font",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "MakersFlow needs access to your photos to set a profile picture."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "MakersFlow needs access to your photos to save certificates.",
          "savePhotosPermission": "MakersFlow needs permission to save certificates to your gallery.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "makersflow",
    "privacy": "unlisted"
  }
}